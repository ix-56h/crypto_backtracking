{
  "_description": "Target full-day crashes. 5% drop over 1 day, target 6% recovery. For those -5% daily candles.",
  "initial_capital": 5000,
  "fee_pct": 0.1,
  "max_concurrent_positions": 5,
  "position_sizing": { "type": "fixed", "value": 400 },
  "rules": [
    {
      "id": "daily_crash",
      "entry": { "type": "price_drop", "percentage": 5.0, "window": "1d" },
      "exit": { "take_profit_pct": 6.0, "stop_loss_pct": 15.0 },
      "max_positions": 5
    }
  ]
}
