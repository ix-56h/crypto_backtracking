{
  "_description": "Cascade: base entry at -3%, add at -3% more from base entry (≈-6% total). Linked positions for deeper conviction.",
  "initial_capital": 5000,
  "fee_pct": 0.1,
  "max_concurrent_positions": 8,
  "position_sizing": { "type": "fixed", "value": 250 },
  "rules": [
    {
      "id": "base_dip",
      "entry": { "type": "price_drop", "percentage": 3.0, "window": "4h" },
      "exit": { "take_profit_pct": 4.0, "stop_loss_pct": 10.0 },
      "max_positions": 4
    },
    {
      "id": "deep_add",
      "entry": { "type": "price_drop", "percentage": 3.0, "window": "4h" },
      "exit": { "take_profit_pct": 5.0, "stop_loss_pct": 12.0 },
      "max_positions": 4,
      "depends_on": {
        "rule_id": "base_dip",
        "condition": "has_open_position",
        "drop_from": "parent_entry"
      }
    }
  ]
}
