{
  "_description": "Triple cascade: -3% base, -2.5% add, -2.5% deep add. Total potential exposure at ~-8% crash with 3 layers.",
  "initial_capital": 5000,
  "fee_pct": 0.1,
  "max_concurrent_positions": 9,
  "position_sizing": { "type": "fixed", "value": 200 },
  "rules": [
    {
      "id": "crash_base",
      "entry": { "type": "price_drop", "percentage": 3.0, "window": "4h" },
      "exit": { "take_profit_pct": 4.0, "stop_loss_pct": 10.0 },
      "max_positions": 3
    },
    {
      "id": "crash_mid",
      "entry": { "type": "price_drop", "percentage": 2.5, "window": "4h" },
      "exit": { "take_profit_pct": 5.0, "stop_loss_pct": 12.0 },
      "max_positions": 3,
      "depends_on": {
        "rule_id": "crash_base",
        "condition": "has_open_position",
        "drop_from": "parent_entry"
      }
    },
    {
      "id": "crash_deep",
      "entry": { "type": "price_drop", "percentage": 2.5, "window": "4h" },
      "exit": { "take_profit_pct": 6.0, "stop_loss_pct": 15.0 },
      "max_positions": 3,
      "depends_on": {
        "rule_id": "crash_mid",
        "condition": "has_open_position",
        "drop_from": "parent_entry"
      }
    }
  ]
}
