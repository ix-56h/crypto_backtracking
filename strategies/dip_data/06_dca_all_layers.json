{
  "_description": "DCA ladder using all 3 thresholds: big median, crash median, extreme. Escalating position size and TP.",
  "initial_capital": 10000,
  "fee_pct": 0.1,
  "max_concurrent_positions": 50,
  "position_sizing": { "type": "fixed", "value": 100 },
  "rules": [
    {
      "id": "big_layer",
      "entry": { "type": "price_drop", "percentage": 3.4, "window": "3h" },
      "exit": { "take_profit_pct": 6, "stop_loss_pct": 10.0 },
      "max_positions": 50
    },
    {
      "id": "crash_layer",
      "entry": { "type": "price_drop", "percentage": 6.5, "window": "4h" },
      "exit": { "take_profit_pct": 5, "stop_loss_pct": 15.0 },
      "max_positions": 50
    },
    {
      "id": "extreme_layer",
      "entry": { "type": "price_drop", "percentage": 10, "window": "5h" },
      "exit": { "take_profit_pct": 9, "stop_loss_pct": 20.0 },
      "max_positions": 50
    }
  ]
}
