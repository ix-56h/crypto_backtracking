{
  "_description": "Cascade: enter on 5% dip, add position if drops 3% more from parent entry. Generous TPs, wide SL.",
  "initial_capital": 5000,
  "fee_pct": 0.1,
  "max_concurrent_positions": 10,
  "position_sizing": { "type": "fixed", "value": 200 },
  "rules": [
    {
      "id": "base_5pct",
      "entry": { "type": "price_drop", "percentage": 5.0, "window": "4h" },
      "exit": { "take_profit_pct": 3.0, "stop_loss_pct": 18.0 },
      "max_positions": 5
    },
    {
      "id": "add_3pct_from_parent",
      "entry": { "type": "price_drop", "percentage": 3.0, "window": "4h" },
      "exit": { "take_profit_pct": 4.5, "stop_loss_pct": 18.0 },
      "max_positions": 5,
      "depends_on": {
        "rule_id": "base_5pct",
        "condition": "has_open_position",
        "drop_from": "parent_entry"
      }
    }
  ]
}
