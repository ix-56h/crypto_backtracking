{
  "initial_capital": 5000,
  "fee_pct": 0.1,
  "max_concurrent_positions": 10,
  "position_sizing": { "type": "fixed", "value": 200 },
  "rules": [
    {
      "id": "base_4pct",
      "entry": { "type": "price_drop", "percentage": 4.0, "window": "2h" },
      "exit": { "take_profit_pct": 2.5, "stop_loss_pct": 15.0 },
      "max_positions": 5
    },
    {
      "id": "child_2pct",
      "entry": { "type": "price_drop", "percentage": 2.0, "window": "2h" },
      "exit": { "take_profit_pct": 3.0, "stop_loss_pct": 15.0 },
      "max_positions": 3,
      "depends_on": {
        "rule_id": "base_4pct",
        "condition": "has_open_position",
        "drop_from": "parent_entry"
      }
    },
    {
      "id": "child_4pct",
      "entry": { "type": "price_drop", "percentage": 4.0, "window": "4h" },
      "exit": { "take_profit_pct": 4.0, "stop_loss_pct": 15.0 },
      "max_positions": 2,
      "depends_on": {
        "rule_id": "base_4pct",
        "condition": "has_open_position",
        "drop_from": "parent_entry"
      }
    }
  ]
}
