      "max_positions": 5
    },
    {
      "id": "pct_l2",
      "entry": { "type": "price_drop", "percentage": 5.0, "window": "4h" },
      "exit": { "take_profit_pct": 3.0, "stop_loss_pct": 15.0 },
      "max_positions": 5
    }
  ]
}
