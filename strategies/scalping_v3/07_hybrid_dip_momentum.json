{
  "initial_capital": 5000,
  "fee_pct": 0.1,
  "max_concurrent_positions": 5,
  "position_sizing": { "type": "fixed", "value": 250 },
  "rules": [
    {
      "id": "hybrid_dip",
      "entry": { "type": "price_drop", "percentage": 4.0, "window": "4h" },
      "exit": { "take_profit_pct": 3.0, "stop_loss_pct": 8.0 },
      "max_positions": 3
    },
    {
      "id": "hybrid_momentum",
      "entry": { "type": "price_rise", "percentage": 4.0, "window": "4h" },
      "exit": { "take_profit_pct": 3.0, "stop_loss_pct": 8.0 },
      "max_positions": 2
    }
  ]
}
